services:
  wazuh.indexer:
    image: "{{ siem_wazuh_indexer_image | default('wazuh/wazuh-indexer:4.14.6') }}"
    restart: unless-stopped
    ports:
      - "9200:9200"
    environment:
      - "OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g"
    volumes:
      - wazuh_indexer_data:/var/lib/wazuh-indexer
      - "{{ siem_config_dir }}/wazuh_indexer_ssl_certs:/usr/share/wazuh-indexer/certs:ro"

  wazuh.manager:
    image: "{{ siem_wazuh_manager_image | default('wazuh/wazuh-manager:4.14.6') }}"
    restart: unless-stopped
    ports:
      - "1514:1514"
      - "1515:1515"
      - "55000:55000"
    volumes:
      - wazuh_manager_data:/var/ossec/data
      - "{{ siem_config_dir }}/ossec.conf:/var/ossec/etc/ossec.conf:ro"

  wazuh.dashboard:
    image: "{{ siem_wazuh_dashboard_image | default('wazuh/wazuh-dashboard:4.14.6') }}"
    restart: unless-stopped
    ports:
      - "443:5601"
    depends_on:
      - wazuh.indexer
      - wazuh.manager
    volumes:
      - "{{ siem_config_dir }}/wazuh_dashboard:/usr/share/wazuh-dashboard/config:ro"

volumes:
  wazuh_indexer_data:
  wazuh_manager_data:
