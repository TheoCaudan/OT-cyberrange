<network>
  <name>{{ item.name }}</name>
  <bridge name="{{ item.bridge }}" stp="{{ item.stp | default('on') }}" delay="{{ item.delay | default('0') }}"/>
  <forward mode="{{ item.forward_mode | default('nat') }}"/>
  <ip address="{{ item.gateway }}" netmask="{{ item.netmask }}">
    {% if item.dhcp_start is defined and item.dhcp_end is defined %}
    <dhcp>
      <range start="{{ item.dhcp_start }}" end="{{ item.dhcp_end }}"/>
    </dhcp>
    {% endif %}
  </ip>
</network>